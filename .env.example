# ──────────────────────────────────────────────────────────────
# MediCore HMS — environment variables
# Copy to .env and fill in with your Supabase project values:
#   Dashboard → Project Settings → Database / API
# ──────────────────────────────────────────────────────────────

# Postgres via Supabase TRANSACTION POOLER (port 6543) — used at runtime.
# Serverless functions must use the pooler or they exhaust connections.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT connection (port 5432) — used by `prisma migrate` and `prisma studio`.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase API (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Service role key — SERVER ONLY, never expose to the client.
# Required by the seed to create demo users, and by admin flows.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Explicit opt-in for demo users (one account per role, publicly-documented
# shared password) — set to "true" for this portfolio's own demo deploy.
# Leave unset for a real deployment: a known shared password should never
# exist just because SUPABASE_SERVICE_ROLE_KEY happens to be configured.
SEED_DEMO_USERS="true"
